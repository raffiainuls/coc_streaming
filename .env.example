# ============================================================
# Environment untuk stack Docker LOKAL
# Pakai: dotenv -f .env-local run dbt run -s +ws_materials --full-refresh
# ============================================================

# RisingWave — diakses dari laptop (host)
RW_HOSTNAME=localhost
RW_PORT=4566
RW_USER=root
RW_PASSWORD=
RW_DB_NAME=dev
RW_SCHEMA=public

# profiles.yml ada di root project ini
DBT_PROFILES_DIR=.

# Kafka — alamat DARI DALAM network Docker, karena yang connect ke Kafka
# adalah server RisingWave (di container), bukan laptop
DEBEZIUM_HOSTNAME=kafka
DEBEZIUM_PORT=29092

# Nama topic CDC Debezium: <topic.prefix>.<database>.<tabel>
# topic.prefix = "coc" (lihat connectors/register-debezium-mysql.sh)
TOPIC_PREFIX=staging_smile5_20260212.

# ClickHouse lokal
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse123
CLICKHOUSE_DB_NAME=bronze_layer
